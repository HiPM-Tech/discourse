# Discourse 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# =============================================================================
# 基础配置
# =============================================================================

# 应用主机名 (必填)
DISCOURSE_HOSTNAME=localhost

# 开发者邮箱 (多个用逗号分隔)
DISCOURSE_DEVELOPER_EMAILS=admin@example.com

# 安全密钥 (生产环境必须修改!)
# 生成命令: openssl rand -hex 64
DISCOURSE_SECRET_KEY_BASE=change_me_in_production_please_use_openssl_rand_hex_64

# =============================================================================
# 数据库配置
# =============================================================================

# PostgreSQL 密码 (生产环境必须修改!)
DISCOURSE_DB_PASSWORD=discourse_password

# Redis 密码 (可选，建议生产环境设置)
DISCOURSE_REDIS_PASSWORD=

# =============================================================================
# SMTP 邮件配置
# =============================================================================

# SMTP 服务器地址
DISCOURSE_SMTP_ADDRESS=smtp.example.com

# SMTP 端口
DISCOURSE_SMTP_PORT=587

# SMTP 用户名
DISCOURSE_SMTP_USER_NAME=your_email@example.com

# SMTP 密码
DISCOURSE_SMTP_PASSWORD=your_smtp_password

# 启用 STARTTLS
DISCOURSE_SMTP_ENABLE_START_TLS=true

# =============================================================================
# 端口配置
# =============================================================================

# HTTP 端口 (开发环境默认 3000，生产环境默认 80)
DISCOURSE_HTTP_PORT=3000

# HTTPS 端口 (生产环境)
DISCOURSE_HTTPS_PORT=443

# PostgreSQL 端口 (开发环境)
POSTGRES_PORT=5432

# Redis 端口 (开发环境)
REDIS_PORT=6379

# MailHog Web 端口 (开发环境)
MAILHOG_WEB_PORT=8025

# MailHog SMTP 端口 (开发环境)
MAILHOG_SMTP_PORT=1025

# Ember CLI 端口 (开发环境)
EMBER_PORT=4200

# =============================================================================
# 性能配置
# =============================================================================

# Unicorn Worker 数量 (根据 CPU 核心数调整)
# 开发环境: 2
# 生产环境: 2-4 每核心
UNICORN_WORKERS=4

# Sidekiq 实例数量
UNICORN_SIDEKIQS=1

# =============================================================================
# 可选配置
# =============================================================================

# MaxMind GeoIP 许可证密钥 (用于地理位置功能)
DISCOURSE_MAXMIND_LICENSE_KEY=

# 预构建镜像标签 (生产环境)
DISCOURSE_IMAGE=ghcr.io/hipm-tech/discourse:latest

# =============================================================================
# 测试配置
# =============================================================================

# 跳过 Lint 检查 (1=跳过)
SKIP_LINT=0

# 跳过测试 (1=跳过)
SKIP_TESTS=0

# 仅运行 Ruby 测试 (1=启用)
RUBY_ONLY=0

# 仅运行 JS 测试 (1=启用)
JS_ONLY=0

# 使用 Turbo 并行测试 (1=启用)
USE_TURBO=0

# 运行系统测试 (1=启用)
RUN_SYSTEM_TESTS=0

# 仅测试指定插件
SINGLE_PLUGIN=

# 生成测试覆盖率报告 (1=启用)
COVERAGE=0
